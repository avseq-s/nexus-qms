# ============================================================
# Nexus QMS — Environment Variables
# Copy this file to .env.local for local development
# ============================================================

# --- Database ---
# Local dev (without Docker): point to your local Postgres instance
DATABASE_URL="postgresql://qms_user:qms_password@localhost:5432/qms_db"

# --- NextAuth ---
# Must be the full URL where the app is hosted
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret-min-32-chars"

# --- PostgreSQL (used by docker-compose) ---
POSTGRES_USER=qms_user
POSTGRES_PASSWORD=qms_password
POSTGRES_DB=qms_db

# --- App ---
PORT=3000
