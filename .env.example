# ============================================================
# Nexus QMS — Environment Variables
# Copy this file to .env.local for local development
# ============================================================

# --- Database (MongoDB) ---
# Local dev (without Docker): point to your local MongoDB instance
# MongoDB Atlas (cloud): replace with your Atlas connection string
DATABASE_URL="mongodb://qms_user:qms_password@localhost:27017/qms_db?authSource=admin"

# --- NextAuth ---
# Must be the full URL where the app is hosted
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret-min-32-chars"

# --- MongoDB (used by docker-compose) ---
MONGO_USER=qms_user
MONGO_PASSWORD=qms_password
MONGO_DB=qms_db

# --- App ---
PORT=3000
