// =============================================================================
// Nexus QMS — Prisma Schema
// Database: MongoDB (via Prisma ODM)
//
// All models use MongoDB ObjectId as the primary key (@db.ObjectId).
// Relations are stored as referenced ObjectId fields — Prisma resolves them
// at query time using the `@relation` directive (no SQL JOIN equivalent).
//
// MongoDB does NOT use migrations. Use `prisma db push` to sync this schema
// to your database, and `prisma db seed` to populate initial data.
// =============================================================================

generator client {
  // Generates the Prisma Client used throughout the Next.js app
  provider = "prisma-client-js"
}

datasource db {
  // Switched from PostgreSQL to MongoDB for free-tier cloud hosting (MongoDB Atlas)
  provider = "mongodb"
  url      = env("DATABASE_URL") // Set in .env.local — see .env.example
}

// =============================================================================
// ENUMS
// MongoDB stores enums as plain strings in the collection.
// =============================================================================

// Defines what each user is allowed to see and do in the system
enum Role {
  ADMIN      // Full access — manage users, system config
  QUALITY    // Run IQC inspections, raise NCRs, approve documents
  STORE      // Receive GRNs, manage inventory reels
  PURCHASE   // Manage suppliers and purchase orders
  PRODUCTION // View inventory and issue reels to production
}

// Tracks the approval lifecycle of a controlled document
enum DocStatus {
  DRAFT     // Being authored — not yet reviewed
  IN_REVIEW // Submitted for review — locked for editing
  APPROVED  // Signed off — effective and in use
  OBSOLETE  // Superseded by a newer revision
}

// Tracks the physical/inspection state of a component reel in the store
enum ReelStatus {
  QUARANTINE // Newly received — awaiting IQC inspection
  ACCEPTED   // IQC passed — cleared for use
  REJECTED   // IQC failed — must be returned or scrapped
  ISSUED     // Picked from store and issued to production
  CONSUMED   // Fully used up in production
  SCRAPPED   // Disposed of (damaged, expired, or failed)
}

// =============================================================================
// MODELS
// =============================================================================

// -----------------------------------------------------------------------------
// User — system account with role-based access
// -----------------------------------------------------------------------------
model User {
  // MongoDB ObjectId — auto-generated 24-char hex string
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique  // Used as the login identifier
  name      String?           // Display name (optional)
  password  String            // bcrypt hash — never stored in plaintext
  role      Role     @default(STORE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relations — Prisma uses these to resolve reverse lookups
  auditLogs      AuditLog[]       // All actions this user performed
  createdDocs    Document[]       @relation("CreatedDocs")   // Documents authored
  reviewedDocs   Document[]       @relation("ReviewedDocs")  // Documents reviewed
  approvedDocs   Document[]       @relation("ApprovedDocs")  // Documents approved
  iqcInspections IqcInspection[]  // IQC inspections conducted
  ncrRecords     NcrRecord[]      // NCRs raised by this user
}

// -----------------------------------------------------------------------------
// Document — ISO 9001 controlled document (SOP, work instruction, policy, etc.)
// -----------------------------------------------------------------------------
model Document {
  id      String    @id @default(auto()) @map("_id") @db.ObjectId
  title   String                    // e.g., "Incoming Inspection Procedure"
  version String                    // e.g., "Rev A", "Rev B"
  content String                    // Full document body (rich text / markdown)
  status  DocStatus @default(DRAFT)

  // Author — mandatory; the user who created this document
  authorId String @db.ObjectId
  author   User   @relation("CreatedDocs", fields: [authorId], references: [id])

  // Reviewer — optional; set when submitted for review
  reviewerId String? @db.ObjectId
  reviewer   User?   @relation("ReviewedDocs", fields: [reviewerId], references: [id])

  // Approver — optional; set when approved
  approverId String? @db.ObjectId
  approver   User?   @relation("ApprovedDocs", fields: [approverId], references: [id])

  effectiveDate DateTime? // Date the approved document comes into force
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// -----------------------------------------------------------------------------
// Supplier — approved vendor list entry
// -----------------------------------------------------------------------------
model Supplier {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  code              String   @unique  // Internal supplier code, e.g., "SUP-001"
  // Approval gate — must be true before any GRN can reference this supplier
  isApproved        Boolean  @default(false)
  // 0–100 score; updated after each delivery (PASS = +5, FAIL = −10, capped)
  performanceRating Float    @default(0.0)
  // Contact details surfaced by the UI on the supplier register page
  contact           String?  // Primary contact person, e.g., "Rahul Verma"
  email             String?  // Contact email
  phone             String?  // Phone (optional in UI)
  gstin             String?  // Tax/GSTIN identifier
  // ISO 9001 certification status — drives the UI's "Approved vs Probation" label
  isIsoCertified    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  grns Grn[] // All goods receipt notes from this supplier
}

// -----------------------------------------------------------------------------
// Component — a part or material in the Bill of Materials (BOM)
// -----------------------------------------------------------------------------
model Component {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  partNumber    String   @unique  // Manufacturer or internal part number
  description   String            // Human-readable description
  category      String            // e.g., "Resistor", "IC", "Capacitor"
  mslLevel      Int      @default(1)   // Moisture Sensitivity Level (IPC/JEDEC J-STD-033)
  shelfLifeDays Int?               // Max storage days; null = no expiry
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reels    Reel[]     // Physical reels of this component in stock
  grnItems GrnItem[]  // Line items on GRNs that include this component
  bomItems BomItem[]  // Used as a primary item in these BOMs
  bomAlternates BomAlternate[] // Used as an alternate item in these BOMs
}

// -----------------------------------------------------------------------------
// Reel — a physical reel/spool of a component held in the store
// -----------------------------------------------------------------------------
model Reel {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  componentId String     @db.ObjectId
  component   Component  @relation(fields: [componentId], references: [id])
  grnId       String     @db.ObjectId
  grn         Grn        @relation(fields: [grnId], references: [id])
  supplierLot String               // Supplier's lot/batch number for traceability
  quantity    Int                  // Current quantity remaining on the reel
  location    String?              // Shelf/bin location, e.g., "SHELF-A1"
  status      ReelStatus @default(QUARANTINE)
  expiryDate  DateTime?            // Calculated from MSL shelf life at time of receipt
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  auditLogs  AuditLog[]   // All movements and status changes for this reel
  ncrRecords NcrRecord[]  // Non-conformance reports raised against this reel
}

// -----------------------------------------------------------------------------
// Grn — Goods Receipt Note; records a physical delivery from a supplier
// -----------------------------------------------------------------------------
model Grn {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  grnNumber    String   @unique  // Sequential number, e.g., "GRN-1092"
  supplierId   String   @db.ObjectId
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  receivedDate DateTime @default(now())
  // Status values: PENDING_IQC | IQC_PASSED | IQC_FAILED | CLOSED
  status       String   @default("PENDING_IQC")

  items GrnItem[] // Line items (one per component type in the delivery)
  reels Reel[]    // Reels created from this GRN
}

// -----------------------------------------------------------------------------
// GrnItem — a single line item within a GRN (one component type per line)
// -----------------------------------------------------------------------------
model GrnItem {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  grnId       String    @db.ObjectId
  grn         Grn       @relation(fields: [grnId], references: [id])
  componentId String    @db.ObjectId
  component   Component @relation(fields: [componentId], references: [id])
  declaredQty Int       // Quantity declared on the supplier's delivery note

  // One-to-one: each GRN line item has at most one IQC inspection record
  iqc IqcInspection?
}

// -----------------------------------------------------------------------------
// IqcInspection — Incoming Quality Control inspection result for a GRN item
// -----------------------------------------------------------------------------
model IqcInspection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  grnItemId   String   @unique @db.ObjectId  // One inspection per GRN line item
  grnItem     GrnItem  @relation(fields: [grnItemId], references: [id])
  inspectorId String   @db.ObjectId
  inspector   User     @relation(fields: [inspectorId], references: [id])
  // "PASS" or "FAIL" — determines whether reels move from QUARANTINE to ACCEPTED/REJECTED
  status      String
  // Flexible JSON for measurement data (dimensions, electrical tests, visual checks, etc.)
  measurements Json?
  remarks     String?  // Free-text notes from the inspector
  createdAt   DateTime @default(now())
}

// -----------------------------------------------------------------------------
// AuditLog — immutable record of every significant action in the system
// Supports ISO 9001 traceability and internal audit requirements
// -----------------------------------------------------------------------------
model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  // Action type: CREATE | UPDATE | DELETE | MOVE | ISSUE | SCRAP
  action     String
  // Which model was affected: REEL | DOCUMENT | GRN | SUPPLIER | USER
  entityType String
  entityId   String   // The _id of the affected document in its collection
  oldValue   Json?    // Snapshot of the record before the change
  newValue   Json?    // Snapshot of the record after the change
  timestamp  DateTime @default(now())

  // Optional direct link to a reel if this log concerns a specific reel movement
  reelId String? @db.ObjectId
  reel   Reel?   @relation(fields: [reelId], references: [id])
}

// -----------------------------------------------------------------------------
// NcrRecord — Non-Conformance Report raised against a rejected or defective reel
// Drives root-cause analysis and Corrective/Preventive Action (CAPA) workflow
// -----------------------------------------------------------------------------
model NcrRecord {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  ncrNumber   String  @unique  // e.g., "NCR-2026-001"
  reelId      String  @db.ObjectId
  reel        Reel    @relation(fields: [reelId], references: [id])
  raisedById  String  @db.ObjectId
  raisedBy    User    @relation(fields: [raisedById], references: [id])
  description String              // What was wrong (defect description)
  rootCause   String?             // Root cause identified during investigation
  capa        String?             // Corrective and Preventive Action agreed upon
  // Status values: OPEN | UNDER_INVESTIGATION | CLOSED
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// MasterBom — Represents the Bill of Materials for a top-level product
// Tracks version and status; audit logs provide ISO 9001 change traceability.
// -----------------------------------------------------------------------------
model MasterBom {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  productName String
  productCode String     @unique  // e.g., "PCBA-SMV2"
  version     String     @default("Rev A") // Revision string
  status      String     @default("DRAFT") // DRAFT, ACTIVE, OBSOLETE
  details     String?    // Optional description or instructions
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items       BomItem[]  // Line items specifying components and quantities
}

// -----------------------------------------------------------------------------
// BomItem — A specific component required inside a Master BOM
// -----------------------------------------------------------------------------
model BomItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  masterBomId String   @db.ObjectId
  masterBom   MasterBom @relation(fields: [masterBomId], references: [id])
  componentId String   @db.ObjectId
  component   Component @relation(fields: [componentId], references: [id])
  quantity    Float    // Quantity required per 1 unit of final product
  reference   String?  // PCB designator, e.g., "R1, R2, C1"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  alternates  BomAlternate[] // Alternate parts that can be subsituted
}

// -----------------------------------------------------------------------------
// BomAlternate — Allowed alternative components for a specific BomItem
// -----------------------------------------------------------------------------
model BomAlternate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bomItemId   String   @db.ObjectId
  bomItem     BomItem   @relation(fields: [bomItemId], references: [id])
  componentId String   @db.ObjectId
  component   Component @relation(fields: [componentId], references: [id])
  isApproved  Boolean   @default(true) // Needs QA approval ideally
  createdAt   DateTime  @default(now())
}

